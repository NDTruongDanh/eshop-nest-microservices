{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/eshop-nest-microservices/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/eshop-nest-microservices/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/eshop-nest-microservices",
  "projects": {
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-gateway/tsconfig.app.json"
      }
    },
    "basket-service": {
      "type": "application",
      "root": "apps/basket-service",
      "entryFile": "main",
      "sourceRoot": "apps/basket-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/basket-service/tsconfig.app.json"
      }
    },
    "catalog-service": {
      "type": "application",
      "root": "apps/catalog-service",
      "entryFile": "main",
      "sourceRoot": "apps/catalog-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/catalog-service/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "contracts": {
      "type": "library",
      "root": "libs/contracts",
      "entryFile": "index",
      "sourceRoot": "libs/contracts/src",
      "compilerOptions": {
        "tsConfigPath": "libs/contracts/tsconfig.lib.json"
      }
    },
    "discount-service": {
      "type": "application",
      "root": "apps/discount-service",
      "entryFile": "main",
      "sourceRoot": "apps/discount-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/discount-service/tsconfig.app.json"
      }
    },
    "eshop-nest-microservices": {
      "type": "application",
      "root": "apps/eshop-nest-microservices",
      "entryFile": "main",
      "sourceRoot": "apps/eshop-nest-microservices/src",
      "compilerOptions": {
        "tsConfigPath": "apps/eshop-nest-microservices/tsconfig.app.json"
      }
    },
    "ordering-service": {
      "type": "application",
      "root": "apps/ordering-service",
      "entryFile": "main",
      "sourceRoot": "apps/ordering-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ordering-service/tsconfig.app.json"
      }
    }
  }
}